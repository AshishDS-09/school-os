# school-os/.env.example
# Copy this to backend/.env and fill in your real values

# ── Database ─────────────────────────────
DATABASE_URL=postgresql://schooladmin:schoolpass123@postgres:5432/schoolos
# Note: use 'postgres' as host (Docker service name), not localhost

# ── Redis ────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Note: use 'redis' as host (Docker service name), not localhost

# ── Security ─────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OpenAI ───────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Supabase ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ── Twilio ───────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── SendGrid ─────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourschool.com

# ── Celery ───────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── App settings ─────────────────────────
APP_NAME=School OS
DEBUG=True
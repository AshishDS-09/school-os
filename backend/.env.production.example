# backend/.env.production.example
# Copy these keys into Railway or your production environment manager.
# Use real values there, not in git.

ENVIRONMENT=production
DATABASE_URL=postgresql://postgres:<db-password>@<db-host>:5432/postgres

# Redis
REDIS_URL=redis://default:<upstash-password>@<upstash-host>:6379/0
CELERY_BROKER_URL=redis://default:<upstash-password>@<upstash-host>:6379/1
CELERY_RESULT_BACKEND=redis://default:<upstash-password>@<upstash-host>:6379/2

# Security
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
SUPABASE_SERVICE_KEY=replace-with-your-supabase-service-role-key

# Twilio
TWILIO_ACCOUNT_SID=replace-with-your-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SendGrid
SENDGRID_API_KEY=replace-with-your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@schoolos.in

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# App
# Use comma-separated origins without trailing slashes.
ALLOWED_ORIGINS=https://school-os-eight.vercel.app,http://localhost:3000
DEBUG=False
